# MongoDB Atlas connection URI (preferred) — get one at https://www.mongodb.com/cloud/atlas (free tier)
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/brazilian-addon-db?retryWrites=true&w=majority
MONGODB_URI=

# Legacy individual variables (used only when MONGODB_URI is not set)
DB_HOST=localhost
DB_PORT=27017
DB_NAME=brazilian-addon-db
DB_USER=
DB_PSK=

# How often (ms) to refresh stale seeders on a stream GET (default 30 days).
SEEDERS_REFRESH_MS=2592000000

# Upstream addon(s) for stream scraping. Comma-separated list — first responder wins.
# Recommended: deploy the Cloudflare Worker in cloudflare-worker/ and point this here
# to bypass Torrentio's cloud-IP block.
TORRENTIO_BASE=https://torrentio.strem.fun

# Shared secret matching the Cloudflare Worker's WORKER_SECRET (optional).
WORKER_SECRET=

# BR torrent indexer. Default is the public community instance.
TORRENT_INDEXER_BASE=https://torrent-indexer.darklyn.org

# ThePirataFilmes API mirrors (comma-separated).
PIRATAFILMES_BASE=https://www.thepiratafilmes.online,https://catalago.online

# Short-lived response cache TTL in ms. Default 30 minutes.
SEARCH_CACHE_TTL_MS=1800000

# Vercel Cron auth secret. Generate any random string and add it on Vercel
# (Settings → Environment Variables → CRON_SECRET).
CRON_SECRET=

# TMDB API key for PT-BR title/description enrichment (optional).
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
